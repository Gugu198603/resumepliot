generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resumes   Resume[]
  sessions  Session[]
}

model Resume {
  id           String           @id @default(cuid())
  userId       String?
  title        String?
  originalText String
  parsedJson   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User?            @relation(fields: [userId], references: [id])
  runs         Run[]
}

model Session {
  id        String    @id @default(cuid())
  userId    String?
  resumeId  String?
  title     String?
  goal      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id])
  runs      Run[]
  messages  Message[]
}

model Run {
  id             String    @id @default(cuid())
  sessionId      String?
  resumeId       String?
  goal           String?
  skillId        String?
  vectorProvider String?
  executionPlan  String?
  resultJson     String?
  createdAt      DateTime  @default(now())
  session        Session?  @relation(fields: [sessionId], references: [id])
  resume         Resume?   @relation(fields: [resumeId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

model JobDescription {
  id           String   @id @default(cuid())
  title        String?
  company      String?
  location     String?
  source       String?  @default("manual")
  sourceUrl    String?
  dedupeKey    String?  @unique
  originalText String
  parsedJson   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  matches      JobMatch[]
}

model JobMatch {
  id          String   @id @default(cuid())
  jobId       String
  resumeId    String?
  matchScore  Int      @default(0)
  resultJson  String?
  createdAt   DateTime @default(now())
  job         JobDescription @relation(fields: [jobId], references: [id])
}
