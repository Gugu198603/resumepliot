generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String?      @unique
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  resumes   Resume[]
  sessions  Session[]
  memories  MemoryItem[]
}

model Resume {
  id           String                  @id @default(cuid())
  userId       String?
  title        String?
  originalText String
  parsedJson   String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  user         User?                   @relation(fields: [userId], references: [id])
  runs         Run[]
  memories     MemoryItem[]
  corrections  ResumeCorrectionEvent[]
  versions     ResumeVersion[]
}

model ResumeVersion {
  id                   String   @id @default(cuid())
  resumeId             String
  jobId                String?
  label                String?
  versionNumber        Int
  contentJson          String
  candidateProfileJson String?
  matchScore           Int?
  createdAt            DateTime @default(now())
  resume               Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, versionNumber])
  @@index([resumeId, createdAt])
  @@index([jobId])
}

model ResumeCorrectionEvent {
  id          String   @id @default(cuid())
  resumeId    String
  errorTypes  String?
  beforeJson  String?
  afterJson   String?
  summaryJson String?
  createdAt   DateTime @default(now())
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt])
  @@index([createdAt])
}

model Session {
  id        String       @id @default(cuid())
  userId    String?
  resumeId  String?
  title     String?
  goal      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User?        @relation(fields: [userId], references: [id])
  runs      Run[]
  messages  Message[]
  memories  MemoryItem[]
}

model Run {
  id             String       @id @default(cuid())
  sessionId      String?
  resumeId       String?
  runtimeRunId   String?
  status         String       @default("pending")
  goal           String?
  skillId        String?
  vectorProvider String?
  executionPlan  String?
  resultJson     String?
  errorCode      String?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  latencyMs      Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  session        Session?     @relation(fields: [sessionId], references: [id])
  resume         Resume?      @relation(fields: [resumeId], references: [id])
  events         RunEvent[]
  memories       MemoryItem[]

  @@index([status, createdAt])
  @@index([runtimeRunId])
  @@index([sessionId, status, createdAt])
  @@index([resumeId, status, createdAt])
}

model RunEvent {
  id           String   @id @default(cuid())
  runId        String
  runtimeRunId String?
  sequence     Int
  type         String
  agent        String?
  status       String?
  latencyMs    Int?
  errorCode    String?
  errorMessage String?
  payloadJson  String?
  createdAt    DateTime @default(now())
  run          Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runtimeRunId, sequence])
  @@index([type, agent])
  @@index([runId, type, sequence])
  @@index([runId, status, sequence])
  @@index([agent, createdAt])
  @@index([errorCode, createdAt])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

model JobDescription {
  id           String       @id @default(cuid())
  title        String?
  company      String?
  location     String?
  source       String?      @default("manual")
  sourceUrl    String?
  dedupeKey    String?      @unique
  originalText String
  parsedJson   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  matches      JobMatch[]
  memories     MemoryItem[]
}

model JobMatch {
  id         String         @id @default(cuid())
  jobId      String
  resumeId   String?
  matchScore Int            @default(0)
  resultJson String?
  createdAt  DateTime       @default(now())
  job        JobDescription @relation(fields: [jobId], references: [id])
}

model Application {
  id              String   @id @default(cuid())
  jobId           String
  resumeVersionId String?
  sessionIdsJson  String?
  status          String   @default("saved")
  appliedAt       DateTime?
  interviewAt     DateTime?
  nextAction      String?
  result          String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([jobId])
  @@index([resumeVersionId])
}

model MemoryItem {
  id                String          @id @default(cuid())
  userId            String?
  resumeId          String?
  sessionId         String?
  jobId             String?
  runId             String?
  scope             String
  type              String
  sourceKind        String?
  sourceId          String?
  title             String?
  content           String
  contentHash       String?
  importance        Float           @default(0.5)
  confidence        Float           @default(1.0)
  accessCount       Int             @default(0)
  lastAccessedAt    DateTime?
  embeddingProvider String?
  vectorProvider    String?
  vectorNamespace   String?
  vectorPointId     String?
  vectorDim         Int?
  status            String          @default("active")
  expiresAt         DateTime?
  metadataJson      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  resume            Resume?         @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  session           Session?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  job               JobDescription? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  run               Run?            @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([scope, type])
  @@index([userId, scope])
  @@index([resumeId, type])
  @@index([sessionId, type])
  @@index([jobId, type])
  @@index([runId])
  @@index([sourceKind, sourceId])
  @@index([vectorNamespace])
  @@index([status, expiresAt])
  @@index([contentHash])
}
