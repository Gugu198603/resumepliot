generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String?      @unique
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  resumes   Resume[]
  sessions  Session[]
  memories  MemoryItem[]
}

model Resume {
  id           String       @id @default(cuid())
  userId       String?
  title        String?
  originalText String
  parsedJson   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User?        @relation(fields: [userId], references: [id])
  runs         Run[]
  memories     MemoryItem[]
}

model Session {
  id        String       @id @default(cuid())
  userId    String?
  resumeId  String?
  title     String?
  goal      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User?        @relation(fields: [userId], references: [id])
  runs      Run[]
  messages  Message[]
  memories  MemoryItem[]
}

model Run {
  id             String       @id @default(cuid())
  sessionId      String?
  resumeId       String?
  goal           String?
  skillId        String?
  vectorProvider String?
  executionPlan  String?
  resultJson     String?
  createdAt      DateTime     @default(now())
  session        Session?     @relation(fields: [sessionId], references: [id])
  resume         Resume?      @relation(fields: [resumeId], references: [id])
  memories       MemoryItem[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

model JobDescription {
  id           String       @id @default(cuid())
  title        String?
  company      String?
  location     String?
  source       String?      @default("manual")
  sourceUrl    String?
  dedupeKey    String?      @unique
  originalText String
  parsedJson   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  matches      JobMatch[]
  memories     MemoryItem[]
}

model JobMatch {
  id         String         @id @default(cuid())
  jobId      String
  resumeId   String?
  matchScore Int            @default(0)
  resultJson String?
  createdAt  DateTime       @default(now())
  job        JobDescription @relation(fields: [jobId], references: [id])
}

model MemoryItem {
  id String @id @default(cuid())

  userId    String?
  resumeId  String?
  sessionId String?
  jobId     String?
  runId     String?

  scope String
  type  String

  sourceKind String?
  sourceId   String?

  title       String?
  content     String
  contentHash String?

  importance     Float     @default(0.5)
  confidence     Float     @default(1.0)
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?

  embeddingProvider String?
  vectorProvider    String?
  vectorNamespace   String?
  vectorPointId     String?
  vectorDim         Int?

  status    String    @default("active")
  expiresAt DateTime?

  metadataJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id])
  resume  Resume?         @relation(fields: [resumeId], references: [id])
  session Session?        @relation(fields: [sessionId], references: [id])
  run     Run?            @relation(fields: [runId], references: [id])
  job     JobDescription? @relation(fields: [jobId], references: [id])

  @@index([scope, type])
  @@index([userId, scope])
  @@index([resumeId, type])
  @@index([sessionId, type])
  @@index([jobId, type])
  @@index([runId])
  @@index([sourceKind, sourceId])
  @@index([vectorNamespace])
  @@index([status, expiresAt])
  @@index([contentHash])
}
