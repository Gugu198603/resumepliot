# Database (Prisma/SQLite). auto provider falls back to JSON file if Prisma is not installed.
# SQLite path is relative to the prisma/ schema dir, so file:./dev.db -> prisma/dev.db
DATABASE_URL="file:./dev.db"
APP_DB_PROVIDER="auto"

# Optional single-instance API protection. Leave empty for local development.
# APP_API_TOKEN="replace-with-a-long-random-token"
# CORS_ORIGINS="http://localhost:5173"
# RATE_LIMIT_WINDOW_MS="60000"
# RATE_LIMIT_MAX="120"
# MAX_RESUME_UPLOAD_BYTES="8388608"

# Vector store: memory (local) or qdrant
VECTOR_STORE_PROVIDER="memory"
# VECTOR_STORE_PROVIDER="qdrant"
# QDRANT_URL="http://localhost:6333"
# QDRANT_COLLECTION="resume_chunks"
# QDRANT_VECTOR_SIZE="1024"
# QDRANT_API_KEY="your_key"
# Retired KnowledgeBaseVersion data is eligible for Qdrant cleanup after this many days.
KB_RETENTION_DAYS="7"
# Optional custom versioned golden dataset file.
# RAG_GOLDEN_DATASET="./datasets/rag-golden.v1.json"

# Agent runtime hard limits
AGENT_MAX_STEPS="12"
AGENT_MAX_TOOL_CALLS="20"
AGENT_MAX_SAME_TOOL_CALLS="4"
AGENT_TIMEOUT_MS="120000"
TOOL_TIMEOUT_MS="30000"

# JSON array of trusted external MCP servers. Keep secrets in the environment/secret manager.
# MCP_EXTERNAL_SERVERS='[{"id":"local","transport":"stdio","command":"node","args":["./server.js"]},{"id":"remote","transport":"streamable-http","url":"https://example.com/mcp"}]'

# Skill Router classifier artifact and CI quality gates.
# SKILL_ROUTER_MODEL="./models/skill-router/naive-bayes-v1.json"
# SKILL_ROUTER_EMBEDDING_MODEL="./models/skill-router/embedding-comparison-v1.json"
# SKILL_ROUTER_DATASET="./datasets/skill-router.v1.json"
SKILL_ROUTER_MIN_ACCURACY="0.8"
SKILL_ROUTER_MIN_MACRO_F1="0.75"
SKILL_ROUTER_MIN_UNKNOWN_RECALL="0.75"
SKILL_ROUTER_EMBEDDING_MIN_ACCURACY="0.85"
SKILL_ROUTER_EMBEDDING_MIN_MACRO_F1="0.85"
SKILL_ROUTER_EMBEDDING_MIN_UNKNOWN_RECALL="0.75"

# Memory: run summary is promoted to session/resume/user memory after N retrieval hits.
MEMORY_PROMOTION_HIT_THRESHOLD="3"

# LLM (chat/completions compatible: OpenAI, gateways, local vLLM/Ollama)
# Leave OPENAI_API_KEY empty to run agents in heuristic fallback mode.
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_TIMEOUT_MS="30000"

# Job scheduler: periodically fetch JDs from configured sources.
# JOB_SCHEDULER_ENABLED="true"
# JOB_SCHEDULER_INTERVAL_MS="21600000"   # 6h
# JOB_SCHEDULER_CONFIG='[{"source":"greenhouse","config":{"boards":["gitlab"],"limit":50,"filter":{"keywords":["engineer","backend"],"excludeKeywords":["manager"],"location":["remote","germany"],"keywordMode":"any"}}},{"source":"lever","config":{"companies":["leverdemo"],"limit":50}}]'
#   filter 字段（可选，仅 greenhouse/lever 生效）：
#     keywords        关键词数组或逗号串，匹配 title+正文
#     keywordMode     "any"(默认任一命中) 或 "all"(全部命中)
#     excludeKeywords 命中即排除
#     location        地域数组或逗号串，匹配 location+title+正文

# Real job sources (public ATS APIs, no auth). Used when config omits boards/companies.
# GREENHOUSE_BOARDS="gitlab,airbnb"      # company board tokens at boards.greenhouse.io/<token>
# LEVER_COMPANIES="leverdemo,netflix"    # company handles at jobs.lever.co/<handle>
