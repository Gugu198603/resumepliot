{
  "name": "resumepilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --env-file=.env server/index.js",
    "dev:client": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "test": "node --test tests/*.test.js",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "db:migrate-json": "node --env-file=.env scripts/migrate-json-to-prisma.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
